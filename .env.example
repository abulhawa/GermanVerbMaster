# Postgres connection string (e.g. Supabase or local `postgres://` URL).
DATABASE_URL=

# Set to `disable` when connecting to a local instance without TLS.
DATABASE_SSL=
PGSSLMODE=

# Comma-separated list of allowed origins for production deployments.
# Leave empty during development to allow the dev client to connect.
APP_ORIGIN=

# Supabase Auth configuration. Use the same Supabase project as the Android app.
SUPABASE_URL=
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional. Defaults to https://gvm.qortxai.com in production and the current localhost origin in development.
VITE_AUTH_SITE_URL=

# Google OAuth is configured in Supabase Auth providers.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Transactional email (Resend).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Groq API key for AI-powered answer leniency checking and B2 feedback.
# Get a free key at console.groq.com
GROQ_API_KEY=

# Toggle admin routes and the React admin console. Defaults to enabled when NODE_ENV
# is not "production". Set to "true" to force-enable on staging or "false" to disable locally.
ENABLE_ADMIN_FEATURES=

# Shared secret required for POST /api/admin/verbs requests when admin features are enabled.
# Set this to a randomly generated string and share it only with corpus moderators.
ADMIN_API_TOKEN=

# Enable lexeme-based task APIs and shadow-mode comparisons. Set to "false"
# to revert to legacy verb-only behaviour during rollback.
ENABLE_LEXEME_SCHEMA=true

# Set to 1 to use Groq for generating richer test fixtures (optional)
TEST_USE_GROQ=
