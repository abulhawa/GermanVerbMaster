{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/delete-account",
      "destination": "/delete-account.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
